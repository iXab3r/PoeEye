@namespace PoeShared.Blazor.Controls
@using Microsoft.JSInterop
@inherits PoeShared.Blazor.BlazorReactiveComponent

@if (HideViaCss || IsOpen)
{
    <div class="reactive-popout__host @(BackdropClass ?? string.Empty)"
         style="@BackdropStyle">
        <div class="reactive-popout__anchor"
             aria-hidden="true"
             @ref="AnchorRef"></div>
        <div class="reactive-popout__panel @(PanelClass ?? string.Empty)"
             style="@PanelStyle"
             popover="manual"
             tabindex="0"
             @ref="PanelRef">
            @ChildContent
        </div>
    </div>
}

@code {
    private static readonly string JsFilePath = "./_content/PoeShared.Blazor.Controls/ReactivePopout.razor.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private DotNetObjectReference<ReactivePopout>? dotNetRef;
    private bool previousIsOpen;
    private bool shouldSkipRender;
    private bool shouldSyncVisibility;

    public ReactivePopout()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JsRuntime.InvokeAsync<IJSObjectReference>("import", JsFilePath).AsTask());
    }

    [Parameter] public bool IsOpen { get; set; }

    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter] public bool CloseOnBackdropPointerDown { get; set; } = true;

    [Parameter] public bool CloseOnEscape { get; set; } = true;

    [Parameter] public string? PanelClass { get; set; }

    [Parameter] public string? PanelStyle { get; set; }

    [Parameter] public string? BackdropClass { get; set; }

    [Parameter] public string? BackdropStyle { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public bool HideViaCss { get; set; }

    private ElementReference AnchorRef { get; set; }

    private ElementReference PanelRef { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (IsOpen != previousIsOpen)
        {
            shouldSyncVisibility = true;

            if (HideViaCss && IsComponentRendered)
            {
                shouldSkipRender = true;
            }
        }

        previousIsOpen = IsOpen;
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (!HideViaCss || !IsComponentRendered || !shouldSyncVisibility)
        {
            return;
        }

        shouldSyncVisibility = false;
        await SyncVisibilityAsync();
    }

    protected override bool ShouldRender()
    {
        if (shouldSkipRender)
        {
            shouldSkipRender = false;
            return false;
        }

        return base.ShouldRender();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        var module = await moduleTask.Value;

        if (firstRender)
        {
            await module.InvokeVoidAsync("ensureReactivePopoutTracking");
        }

        if (shouldSyncVisibility)
        {
            shouldSyncVisibility = false;
            await SyncVisibilityAsync();
            return;
        }

        if (!IsOpen)
        {
            return;
        }

        await module.InvokeVoidAsync("repositionReactivePopout", PanelRef, AnchorRef);
    }

    [JSInvokable]
    public Task HandleJsCloseRequest()
    {
        return CloseAsync();
    }

    private async Task CloseAsync()
    {
        if (IsOpenChanged.HasDelegate)
        {
            await IsOpenChanged.InvokeAsync(false);
        }
    }

    private async Task SyncVisibilityAsync()
    {
        dotNetRef ??= DotNetObjectReference.Create(this);
        var module = await moduleTask.Value;

        await module.InvokeVoidAsync(
            "syncReactivePopout",
            PanelRef,
            AnchorRef,
            IsOpen,
            dotNetRef,
            new
            {
                closeOnBackdropPointerDown = CloseOnBackdropPointerDown,
                closeOnEscape = CloseOnEscape,
            });
    }

    public override async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();

        if (moduleTask.IsValueCreated)
        {
            var module = await moduleTask.Value;
            try
            {
                await module.InvokeVoidAsync("disposeReactivePopout", PanelRef);
            }
            catch (JSException)
            {
                // The element might already be gone if the component was removed by a parent render.
            }
            catch (InvalidOperationException)
            {
                // ElementReference is no longer available during teardown, which is safe to ignore here.
            }

            await module.DisposeJsSafeAsync();
        }

        await base.DisposeAsync();
    }
}
