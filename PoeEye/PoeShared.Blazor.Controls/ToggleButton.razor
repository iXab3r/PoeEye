@inherits PoeShared.Blazor.BlazorReactiveComponent

<span @onclick:stopPropagation="true"
      @onmousedown:stopPropagation="true"
      @onmouseup:stopPropagation="true"
      @ondblclick:stopPropagation="true">
    <input type="checkbox"
           id="@Id"
           class="toggle-checkbox"
           title="@Title"
           @bind:get="@IsChecked"
           @bind:set="@HandleCheckedChanged"
           @bind:event="oninput"/>
    <label for="@Id"
           class="@(new CssBuilder("btn").AddClass(string.IsNullOrEmpty(Class) ? "btn-outline-secondary border-0" : Class))"
           style="@Style">
        @ChildContent
    </label>
</span>
