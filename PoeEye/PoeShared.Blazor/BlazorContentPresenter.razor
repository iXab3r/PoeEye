@using PoeShared.Blazor.Scaffolding
@using PoeShared.Blazor.Wpf
@inherits ReactiveComponentBase

@if (currentException == null)
{
    <BlazorErrorBoundary OnError="@HandleBoundaryErrorAsync">
        <ChildContent>
            @if (ResolvedViewType != null)
            {
                @DynamicView
            }
            else
            {
                if (Content == null)
                {
                    <div>Content is not set</div>
                }
                else
                {
                    if (NotFoundTemplate != null)
                    {
                        @NotFoundTemplate
                    }
                    else
                    {
                        <div>View for @($"{Content.GetType()}") is not resolved</div>
                    }
                }
            }
        </ChildContent>
    </BlazorErrorBoundary>
}
else
{
    <div @key="currentException"
         class="blazor-content-fault-host"
         role="alert"
         tabindex="0"
         aria-label="@FaultTooltip"
         title="@FaultTooltip">
        <div class="blazor-content-fault">
            <div class="blazor-content-fault__bar">
                <span class="blazor-content-fault__icon" aria-hidden="true">!</span>

                <div class="blazor-content-fault__summary">
                    <div class="blazor-content-fault__title">Component exception</div>
                    <div class="blazor-content-fault__message">
                        <strong>@currentException.GetType().Name</strong>: @currentException.Message
                    </div>
                </div>

                <div class="blazor-content-fault__actions">
                    <button type="button"
                            class="blazor-content-fault__button"
                            @onclick="Recover">
                        Recover
                    </button>

                    @if (blazorHostController != null)
                    {
                        <button type="button"
                                class="blazor-content-fault__button"
                                @onclick="ReloadHost">
                            Reload
                        </button>
                    }
                </div>
            </div>

            <div class="blazor-content-fault__description">
                This part of the editor failed to render.
            </div>

            <details class="blazor-content-fault__details">
                <summary>Details</summary>
                <div class="blazor-content-fault__metadata">
                    <div>View: @(ResolvedViewType?.FullName ?? ViewType?.FullName ?? "unknown")</div>
                    <div>Content: @(Content?.GetType().FullName ?? "unknown")</div>
                </div>
                <pre class="blazor-content-fault__stack">@currentException</pre>
            </details>
        </div>
    </div>
}

@code {
    private Exception currentException;
    private Exception lastLoggedException;
    private object lastRecoveredContent;
    private Type lastRecoveredViewType;
    private object lastRecoveredViewTypeKey;
    
    [Parameter] public RenderFragment NotFoundTemplate { get; set; }

    protected override void OnParametersSet()
    {
        if (!HasRecoverableViewChanged())
        {
            return;
        }

        lastRecoveredContent = Content;
        lastRecoveredViewType = ViewType;
        lastRecoveredViewTypeKey = ViewTypeKey;
        currentException = null;
        lastLoggedException = null;
    }

    private void Recover()
    {
        currentException = null;
        lastLoggedException = null;
    }

    private async Task ReloadHost()
    {
        currentException = null;
        lastLoggedException = null;
        var hostController = blazorHostController ?? GetBlazorHostController();
        if (hostController != null)
        {
            await hostController.Reload();
        }
    }

    private async Task HandleBoundaryErrorAsync(Exception exception)
    {
        currentException = exception;
        _ = GetBlazorHostController();
        TrackException(exception);
        await InvokeAsync(StateHasChanged);
    }

    private void TrackException(Exception exception)
    {
        if (exception == null || ReferenceEquals(lastLoggedException, exception))
        {
            return;
        }

        lastLoggedException = exception;
        Log.Error("BlazorContentPresenter encountered an error", exception);
    }

    private bool HasRecoverableViewChanged()
    {
        return !ReferenceEquals(lastRecoveredContent, Content) ||
               lastRecoveredViewType != ViewType ||
               !Equals(lastRecoveredViewTypeKey, ViewTypeKey);
    }

    private string FaultTooltip => currentException == null
        ? string.Empty
        : $"{currentException.GetType().Name}: {currentException.Message}";

    public override ValueTask DisposeAsync()
    {
        lastLoggedException = null;
        return base.DisposeAsync();
    }
}
