@using Microsoft.JSInterop
@inject IJSRuntime JsRuntime

<div data-testid="@BuildTestId("panel")" class="d-flex flex-column gap-2">
    <button data-testid="@BuildTestId("throw-sync")" type="button" @onclick="ThrowException">Throw Exception</button>
    <button data-testid="@BuildTestId("throw-async")" type="button" @onclick="ThrowExceptionAsync">Awaited task throws</button>
    <button data-testid="@BuildTestId("throw-render-tree")" type="button" @onclick="ThrowRenderTreeException">Throw RenderTree Exception</button>
    <button data-testid="@BuildTestId("throw-js-async")" type="button" @onclick="ThrowJsExceptionAsync">Awaited JS Exception</button>
    <button data-testid="@BuildTestId("throw-js-unawaited")" type="button" @onclick="ThrowJsExceptionUnawaited">Un-awaited JS Exception</button>
    <button data-testid="@BuildTestId("throw-unawaited")" type="button" @onclick="ThrowExceptionUnawaited">Un-awaited task throws</button>
    <button data-testid="@BuildTestId("gc-collect")" type="button" @onclick="GcCollect">GC Collect</button>
</div>

@if (renderInvalidTree)
{
    <div><button @onclick="ThrowException" @qq="test">qwe</button></div>
}

@code {
    private bool renderInvalidTree;

    [Parameter]
    public string TestIdPrefix { get; set; } = "exception-panel";

    private static void GcCollect()
    {
        GC.Collect();
    }

    private void ThrowExceptionUnawaited()
    {
        _ = ThrowExceptionAsync();
    }

    private async Task ThrowExceptionAsync()
    {
        await Task.Delay(10);
        throw new Exception("This is some async exception.");
    }

    private static void ThrowException()
    {
        throw new Exception("This is some unhandled exception.");
    }

    private async Task ThrowJsExceptionAsync()
    {
        await JsRuntime.InvokeVoidAsync("throwException", "generic JS exception");
    }

    private void ThrowRenderTreeException()
    {
        renderInvalidTree = true;
    }

    private void ThrowJsExceptionUnawaited()
    {
        _ = JsRuntime.InvokeVoidAsync("throwException", "un-awaited generic JS exception");
    }

    private string BuildTestId(string suffix) => $"{TestIdPrefix}-{suffix}";
}
